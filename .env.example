# GraphQL endpoint for the daTryp Node backend (user/trip data)
VITE_GRAPHQL_URL=http://localhost:4000/graphql

# GraphQL endpoint for the daTryp Python backend (recommender, ML, analytics)
VITE_PYTHON_GRAPHQL_URL=http://localhost:8000/graphql

# REST base for the Python backend (auth: /auth/signup, /auth/login, /auth/me).
# Same host as VITE_PYTHON_GRAPHQL_URL, just without the /graphql suffix.
VITE_PYTHON_API_URL=http://localhost:8000

# Google Sign-In OAuth Client ID. Get one from Google Cloud Console:
# APIs & Services → Credentials → OAuth 2.0 Client ID, Web application.
# Add http://localhost:3000 to Authorized JavaScript origins. Leave
# blank to disable the "Continue with Google" button.
VITE_GOOGLE_CLIENT_ID=
