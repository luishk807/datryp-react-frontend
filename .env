# Sidestepping phantom uvicorn listeners on ports 8000 and 8001 — point
# the frontend at port 8002 instead. After a reboot (which clears the
# orphan sockets), revert to 8000 and delete this override.
VITE_PYTHON_API_URL=http://localhost:8002
VITE_PYTHON_GRAPHQL_URL=http://localhost:8002/graphql

# Google Sign-In OAuth Client ID — paste in the value from Google Cloud
# Console (APIs & Services → Credentials → OAuth 2.0 Client ID, Web app).
# Without this, the "Continue with Google" button on the auth page shows
# a configuration hint instead of the real Google button.
VITE_GOOGLE_CLIENT_ID=
